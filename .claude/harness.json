{
  "language": "Rust",
  "framework": null,
  "packageManager": "cargo",
  "typecheck": {
    "command": "cargo check",
    "perFile": false
  },
  "test": {
    "command": "cargo test --all-targets -- --test-threads=1",
    "framework": "cargo test"
  },
  "qualityRules": {
    "builtIn": ["no-confirm-alert", "no-transition-all"],
    "custom": []
  },
  "protectedFiles": [
    ".claude/settings.json",
    ".claude/hooks/*"
  ],
  "features": {
    "intakeScanner": true,
    "telemetry": true
  }
}
